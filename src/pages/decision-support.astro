<!-- ===== Interactive JavaScript ===== -->
<script>
  /* ---------- Tab switching ---------- */
  const tabs = document.querySelectorAll<HTMLButtonElement>('.hero-tab');
  const panels = document.querySelectorAll<HTMLElement>('.strategy-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach(t => { t.classList.remove('hero-tab--active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach(p => p.classList.remove('strategy-panel--active'));
      tab.classList.add('hero-tab--active');
      tab.setAttribute('aria-selected', 'true');
      const panel = document.getElementById(`tab-${target}`);
      if (panel) panel.classList.add('strategy-panel--active');
      panel?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });

  /* ---------- Checklist scoring ---------- */
  function setupChecklist(containerId: string, scoreId: string) {
    const container = document.getElementById(containerId);
    const scoreEl = document.getElementById(scoreId);
    if (!container || !scoreEl) return;
    const checkboxes = container.querySelectorAll<HTMLInputElement>('input[type="checkbox"]');
    const total = checkboxes.length;

    function update() {
      const checked = Array.from(checkboxes).filter(c => c.checked).length;
      const pct = Math.round((checked / total) * 100);
      let level = 'red';
      let msg = 'Significant concerns — do not proceed without resolving all unchecked items.';
      if (pct >= 88) { level = 'green'; msg = 'Strong buy signal — most critical criteria are met.'; }
      else if (pct >= 63) { level = 'yellow'; msg = 'Proceed with caution — address unchecked items before committing.'; }
      scoreEl.innerHTML = `
        <div class="score-bar-wrap"><div class="score-bar score-bar--${level}" style="width:${pct}%"></div></div>
        <p class="score-text score-text--${level}"><strong>${checked} / ${total} criteria met (${pct}%)</strong> — ${msg}</p>
      `;
      scoreEl.style.display = 'block';
    }
    checkboxes.forEach(cb => cb.addEventListener('change', update));
  }

  setupChecklist('checklist-hybrid', 'checklist-hybrid-score');
  setupChecklist('checklist-owner', 'checklist-owner-score');
  setupChecklist('checklist-landlord', 'checklist-landlord-score');
  setupChecklist('checklist-investor', 'checklist-investor-score');

  /* ---------- Financial Calculator ---------- */
  document.getElementById('calcBtn')?.addEventListener('click', () => {
    const val = (id: string) => parseFloat((document.getElementById(id) as HTMLInputElement)?.value || '0');

    const price = val('purchasePrice');
    const dpPct = val('downPayment') / 100;
    const rate = val('interestRate') / 100 / 12;
    const n = val('loanTerm') * 12;
    const rent = val('monthlyRent');
    const hoa = val('hoaFee');
    const tax = val('propertyTax') / 12;
    const ins = val('insurance') / 12;
    const vacPct = val('vacancyRate') / 100;
    const mgmtPct = val('mgmtFee') / 100;
    const capexPct = val('capexRate') / 100;
    const closingCostsPct = val('closingCostsPct') / 100;

    const loanAmt = price * (1 - dpPct);
    const downAmt = price * dpPct;
    const closingCosts = price * closingCostsPct;
    const totalCash = downAmt + closingCosts;

    // Mortgage payment (P&I)
    let mortgage = 0;
    if (rate > 0 && n > 0) {
      mortgage = loanAmt * (rate * Math.pow(1 + rate, n)) / (Math.pow(1 + rate, n) - 1);
    }

    // Income & expenses
    const egi = rent * (1 - vacPct);
    const mgmt = rent * mgmtPct;
    const capex = rent * capexPct;
    const totalExpenses = mortgage + hoa + tax + ins + mgmt + capex;
    const cashFlow = egi - totalExpenses;

    // Metrics
    const annualNOI = (egi - (hoa + tax + ins + capex)) * 12;
    const capRate = price > 0 ? (annualNOI / price) * 100 : 0;
    const annualCashFlow = cashFlow * 12;
    const coc = totalCash > 0 ? (annualCashFlow / totalCash) * 100 : 0;
    const grm = rent > 0 ? price / (rent * 12) : 0;

    const fmt = (n: number) => '$' + Math.round(n).toLocaleString();
    const fmtPct = (n: number) => n.toFixed(2) + '%';

    (document.getElementById('r-mortgage') as HTMLElement).textContent = fmt(mortgage);
    (document.getElementById('r-egi') as HTMLElement).textContent = fmt(egi);
    (document.getElementById('r-expenses') as HTMLElement).textContent = fmt(totalExpenses);
    const cfEl = document.getElementById('r-cashflow') as HTMLElement;
    cfEl.textContent = fmt(cashFlow) + '/mo';
    cfEl.style.color = cashFlow >= 0 ? 'var(--color-success)' : '#e74c3c';
    (document.getElementById('r-caprate') as HTMLElement).textContent = fmtPct(capRate);
    const cocEl = document.getElementById('r-coc') as HTMLElement;
    cocEl.textContent = fmtPct(coc);
    cocEl.style.color = coc >= 6 ? 'var(--color-success)' : coc >= 3 ? 'var(--color-gold)' : '#e74c3c';
    (document.getElementById('r-grm') as HTMLElement).textContent = grm.toFixed(1) + 'x';
    (document.getElementById('r-totalcash') as HTMLElement).textContent = fmt(totalCash);

    // Deal rating
    let rating = 0;
    let signals: string[] = [];
    if (cashFlow > 0) { rating++; signals.push('✅ Positive cash flow'); } else { signals.push('❌ Negative cash flow'); }
    if (capRate >= 5) { rating++; signals.push('✅ Cap rate ≥5%'); } else { signals.push('⚠️ Cap rate below 5%'); }
    if (coc >= 6) { rating++; signals.push('✅ CoC return ≥6%'); } else { signals.push('⚠️ CoC return below 6%'); }
    if (grm <= 16) { rating++; signals.push('✅ GRM ≤16'); } else { signals.push('⚠️ GRM above 16'); }

    let ratingLabel = rating >= 4 ? '🟢 Strong Deal' : rating >= 3 ? '🟡 Marginal Deal' : rating >= 2 ? '🟠 Weak Deal' : '🔴 Deal Fails Investment Tests';
    const ratingEl = document.getElementById('dealRating') as HTMLElement;
    ratingEl.innerHTML = `
      <h4 style="margin-bottom:0.75rem;">${ratingLabel}</h4>
      <ul style="list-style:none;padding:0;font-size:0.9rem;display:flex;flex-direction:column;gap:0.35rem;">
        ${signals.map(s => `<li>${s}</li>`).join('')}
      </ul>
    `;
    ratingEl.className = `deal-rating deal-rating--${rating >= 4 ? 'green' : rating >= 3 ? 'yellow' : 'red'}`;
    ratingEl.style.display = 'block';
    (document.getElementById('resultCards') as HTMLElement).style.display = 'grid';
  });

  /* ---------- Accordion ---------- */
  document.querySelectorAll<HTMLButtonElement>('.accordion-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.accordion-item') as HTMLElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      // Close all
      document.querySelectorAll<HTMLButtonElement>('.accordion-btn').forEach(b => {
        b.setAttribute('aria-expanded', 'false');
        b.closest('.accordion-item')?.classList.remove('accordion-item--open');
      });
      // Toggle clicked
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        item.classList.add('accordion-item--open');
      }
    });
  });
</script>

<style>
  /* ===== Hero Tabs ===== */
  .hero-tabs {
    display: flex;
    flex-wrap: wrap;
