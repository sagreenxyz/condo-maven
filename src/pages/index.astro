---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Home"
  description="CondoMaven — Your expert guide to building and maintaining a condominium investment portfolio from the ground up."
>
  <!-- ===== Hero Section ===== -->
  <section class="hero">
    <div class="hero__bg-pattern" aria-hidden="true"></div>
    <div class="hero__content container">
      <span class="badge badge-gold">For First-Time Condo Investors</span>
      <h1 class="hero__title">Your Expert Guide to<br /><span class="text-gold">Condo Investing</span></h1>
      <p class="hero__sub">
        From your first unit purchase to managing a thriving portfolio, CondoMaven gives you the real-world
        knowledge, practical frameworks, and confidence to succeed in condominium investing — even if you're
        starting with zero experience.
      </p>
      <div class="hero__cta">
        <a href="/roadmap" class="btn btn-primary">View the Roadmap →</a>
        <a href="/faq" class="btn btn-outline">Explore the FAQ</a>
      </div>
    </div>
    <div class="hero__scroll-hint" aria-hidden="true">↓</div>
  </section>

  <!-- ===== About / Concept Section ===== -->
  <section class="section" id="about">
    <div class="container">
      <div class="section-label">What Is CondoMaven?</div>
      <div class="about__grid">
        <div class="about__text">
          <h2>Turn Real Estate Ambition Into a Real Portfolio</h2>
          <hr class="divider--gold" style="margin-left:0;" />
          <p>
            CondoMaven is an informational resource built specifically for individual investors who want to
            build a portfolio of condominium units. Unlike generic real estate advice, everything here
            focuses on the unique dynamics of condo ownership: HOA governance, shared amenities, urban
            density markets, and multi-unit management at a human scale.
          </p>
          <p>
            The site is written from the perspective of someone who has <em>been there</em> — an experienced
            real estate agent and developer with decades of hands-on condo investment experience who knows
            exactly what questions first-timers don't know to ask.
          </p>
          <div class="callout">
            <strong>Disclaimer:</strong> CondoMaven is for educational and informational purposes only.
            Nothing here constitutes financial, legal, or tax advice. Always consult qualified professionals
            before making investment decisions.
          </div>
        </div>
        <div class="about__stats">
          <div class="stat-card">
            <div class="stat-card__icon">🏢</div>
            <div class="stat-card__num">1→Many</div>
            <div class="stat-card__label">Scale from a single unit to a full portfolio</div>
          </div>
          <div class="stat-card">
            <div class="stat-card__icon">📋</div>
            <div class="stat-card__num">Step-by-Step</div>
            <div class="stat-card__label">Structured roadmap from concept to cash flow</div>
          </div>
          <div class="stat-card">
            <div class="stat-card__icon">💡</div>
            <div class="stat-card__num">Expert-Backed</div>
            <div class="stat-card__label">Decades of real-world condo experience</div>
          </div>
          <div class="stat-card">
            <div class="stat-card__icon">🆓</div>
            <div class="stat-card__num">Free Resource</div>
            <div class="stat-card__label">Open, accessible knowledge for every investor</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Scope Section ===== -->
  <section class="section section--alt" id="scope">
    <div class="container">
      <div class="section-label">Our Scope</div>
      <h2 class="text-center">What We Cover</h2>
      <p class="scope__intro text-center text-muted">
        CondoMaven walks you through every phase of the condo investing journey, from market research
        to exit strategy. Here's a snapshot of the core topics you'll find on this site.
      </p>
      <div class="card-grid">
        <div class="card">
          <div class="card__icon">🔍</div>
          <h3>Market Research &amp; Selection</h3>
          <p class="text-muted">How to identify high-performing condo markets, evaluate neighborhoods, and compare comparable sales before making an offer.</p>
        </div>
        <div class="card">
          <div class="card__icon">💰</div>
          <h3>Financing &amp; Acquisition</h3>
          <p class="text-muted">Mortgage types for investment condos, down-payment strategies, HOA financial review, and negotiating purchase price.</p>
        </div>
        <div class="card">
          <div class="card__icon">📑</div>
          <h3>Due Diligence</h3>
          <p class="text-muted">Reading condo declarations, bylaws, reserve fund studies, meeting minutes, and special assessment history before you close.</p>
        </div>
        <div class="card">
          <div class="card__icon">🔑</div>
          <h3>Tenant Management</h3>
          <p class="text-muted">Screening tenants, setting rental rates, lease agreements, navigating rental restrictions, and minimizing vacancy.</p>
        </div>
        <div class="card">
          <div class="card__icon">🏗️</div>
          <h3>Maintenance &amp; CapEx</h3>
          <p class="text-muted">Understanding owner vs. HOA responsibilities, budgeting for capital expenditures, and managing in-unit renovations.</p>
        </div>
        <div class="card">
          <div class="card__icon">📊</div>
          <h3>Portfolio Growth</h3>
          <p class="text-muted">Scaling from one unit to many: BRRRR strategy adapted for condos, refinancing, 1031 exchanges, and portfolio analytics.</p>
        </div>
        <div class="card">
          <div class="card__icon">⚖️</div>
          <h3>Legal &amp; Tax Considerations</h3>
          <p class="text-muted">Entity structuring, depreciation, passive income rules, HOA compliance, and when you need an attorney vs. a CPA.</p>
        </div>
        <div class="card">
          <div class="card__icon">🚪</div>
          <h3>Exit Strategies</h3>
          <p class="text-muted">Timing your sale, 1031 exchanges, converting rentals to short-term rentals, owner-occupancy, and legacy planning.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Why Condos Section ===== -->
  <section class="section section--dark" id="why-condos">
    <div class="container">
      <div class="section-label" style="color: var(--color-gold);">Why Condos?</div>
      <h2 class="text-center">The Case for Condo Investing</h2>
      <p class="text-center" style="color:rgba(255,255,255,0.75); max-width:600px; margin:0 auto 3rem;">
        Condominiums offer a unique entry point into real estate — lower price points, built-in maintenance structures,
        and strong urban demand.
      </p>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-card__icon">🏙️</div>
          <h4>Lower Entry Cost</h4>
          <p>Condos typically cost less than single-family homes in the same market, making your first investment more accessible.</p>
        </div>
        <div class="why-card">
          <div class="why-card__icon">🔧</div>
          <h4>Shared Maintenance</h4>
          <p>The HOA manages exterior upkeep, landscaping, and common areas — reducing your hands-on management burden.</p>
        </div>
        <div class="why-card">
          <div class="why-card__icon">📈</div>
          <h4>Urban Demand</h4>
          <p>Condos in walkable, urban neighborhoods attract high-quality tenants and benefit from long-term appreciation.</p>
        </div>
        <div class="why-card">
          <div class="why-card__icon">🌐</div>
          <h4>Geographic Diversification</h4>
          <p>Lower price points allow investors to hold units in multiple markets, spreading risk across different economies.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA / Navigation Section ===== -->
  <section class="section" id="explore">
    <div class="container">
      <h2 class="text-center">Ready to Begin Your Journey?</h2>
      <p class="text-center text-muted" style="max-width: 540px; margin: 0 auto 3rem;">
        Explore our structured roadmap to see where this resource is headed, or dive into the FAQ
        to tackle the questions every new condo investor faces.
      </p>
      <div class="cta-cards">
        <a href="/roadmap" class="cta-card">
          <div class="cta-card__icon">🗺️</div>
          <h3>Project Roadmap</h3>
          <p>See the development plan and upcoming content milestones for CondoMaven.</p>
          <span class="cta-card__link">Explore the Roadmap →</span>
        </a>
        <a href="/faq" class="cta-card">
          <div class="cta-card__icon">❓</div>
          <h3>Investor FAQ</h3>
          <p>Get answers to the most common questions new condo investors ask before getting started.</p>
          <span class="cta-card__link">Read the FAQ →</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===== Hero ===== */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(150deg, var(--color-navy) 0%, #1a3f5c 50%, #0d2b45 100%);
    overflow: hidden;
    text-align: center;
    padding: 6rem 1.5rem 4rem;
  }

  .hero__bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse at 80% 20%, rgba(201,168,76,0.18) 0%, transparent 50%),
      radial-gradient(ellipse at 20% 80%, rgba(46,134,171,0.15) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 780px;
  }

  .hero__title {
    color: var(--color-white);
    margin: 1.25rem 0;
    line-height: 1.15;
  }

  .hero__sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255,255,255,0.82);
    max-width: 640px;
    margin: 0 auto 2.5rem;
    line-height: 1.75;
  }

  .hero__cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.4);
    font-size: 1.5rem;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ===== Section label ===== */
  .section-label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
    text-align: center;
  }

  /* ===== About ===== */
  .about__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-top: 2.5rem;
  }

  .about__text h2 {
    margin-bottom: 1.25rem;
  }

  .about__text p {
    color: var(--color-text-muted);
  }

  .about__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stat-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .stat-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .stat-card__icon {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .stat-card__num {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 0.35rem;
  }

  .stat-card__label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  /* ===== Scope ===== */
  .scope__intro {
    max-width: 600px;
    margin: 0.75rem auto 0;
    font-size: 1.05rem;
  }

  .card__icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .card h3 {
    margin-bottom: 0.6rem;
    font-size: 1.1rem;
  }

  .card p {
    font-size: 0.9rem;
    margin: 0;
  }

  /* ===== Why Condos ===== */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .why-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-md);
    padding: 2rem 1.5rem;
    transition: background 0.25s;
  }

  .why-card:hover {
    background: rgba(255,255,255,0.1);
  }

  .why-card__icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .why-card h4 {
    color: var(--color-gold-light);
    margin-bottom: 0.6rem;
    font-size: 1.05rem;
  }

  .why-card p {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.72);
    margin: 0;
  }

  /* ===== CTA cards ===== */
  .cta-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .cta-card {
    display: block;
    background: var(--color-white);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem;
    text-align: center;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
  }

  .cta-card:hover {
    border-color: var(--color-gold);
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    color: var(--color-text);
  }

  .cta-card__icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .cta-card h3 {
    margin-bottom: 0.75rem;
  }

  .cta-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .cta-card__link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-gold);
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .cta-cards {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      padding: 5rem 1.25rem 4rem;
    }
  }
</style>
